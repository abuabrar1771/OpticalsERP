{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sacrifice-ravishing-nail.ngrok-free.dev/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "ngrok-skip-browser-warning",
          "value": "true"
        }
      ]
    }
  ]
}